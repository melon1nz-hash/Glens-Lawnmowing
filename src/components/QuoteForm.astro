---
/** Netlify form: data-netlify="true", name="contact", method="POST". Hidden honeypot for spam. */
const serviceTypes = [
  'Lawn mowing',
  'Trimming & edging',
  'Full lawn care',
  'One-off tidy',
  'Other',
];
---

<section id="request-quote" class="py-[var(--section-py)] bg-[var(--color-bg)]" aria-labelledby="quote-form-heading">
  <div class="container-narrow max-w-2xl mx-auto">
    <h2 id="quote-form-heading" class="text-[var(--text-4xl)] font-bold text-[var(--color-text)] mb-8 text-center">
      Request a quote
    </h2>
    <p id="form-success" class="hidden mb-6 p-4 rounded-lg bg-[var(--color-forest)]/10 text-[var(--color-forest)] font-semibold text-center" role="status">
      Thanks for your request. We’ll be in touch soon.
    </p>
    <form
      name="contact"
      method="POST"
      data-netlify="true"
      data-netlify-honeypot="bot-field"
      action="/?form=submitted"
      class="flex flex-col gap-6"
    >
      <input type="hidden" name="form-name" value="contact" />
      <!-- Honeypot: hidden from users, leave empty -->
      <p class="absolute -left-[9999px] w-px h-px overflow-hidden" aria-hidden="true">
        <label for="bot-field">Don’t fill this out</label>
        <input id="bot-field" name="bot-field" type="text" tabindex="-1" autocomplete="off" />
      </p>

      <label for="contact-name" class="text-[1rem] font-semibold text-[var(--color-text)]">
        Name <span class="text-[var(--color-forest)]">*</span>
      </label>
      <input
        id="contact-name"
        type="text"
        name="name"
        required
        autocomplete="name"
        class="w-full px-4 py-3 text-[1rem] border border-[var(--color-slate)]/30 rounded-lg focus:outline-none focus:ring-2 focus:ring-[var(--color-forest)] focus:border-transparent"
      />

      <label for="contact-phone" class="text-[1rem] font-semibold text-[var(--color-text)]">
        Phone <span class="text-[var(--color-forest)]">*</span>
      </label>
      <input
        id="contact-phone"
        type="tel"
        name="phone"
        required
        autocomplete="tel"
        class="w-full px-4 py-3 text-[1rem] border border-[var(--color-slate)]/30 rounded-lg focus:outline-none focus:ring-2 focus:ring-[var(--color-forest)] focus:border-transparent"
      />

      <label for="contact-suburb" class="text-[1rem] font-semibold text-[var(--color-text)]">
        North Shore suburb
      </label>
      <input
        id="contact-suburb"
        type="text"
        name="suburb"
        autocomplete="address-level2"
        placeholder="e.g. Takapuna, Devonport"
        class="w-full px-4 py-3 text-[1rem] border border-[var(--color-slate)]/30 rounded-lg focus:outline-none focus:ring-2 focus:ring-[var(--color-forest)] focus:border-transparent"
      />

      <label for="contact-service" class="text-[1rem] font-semibold text-[var(--color-text)]">
        Service type
      </label>
      <select
        id="contact-service"
        name="serviceType"
        class="w-full px-4 py-3 text-[1rem] border border-[var(--color-slate)]/30 rounded-lg focus:outline-none focus:ring-2 focus:ring-[var(--color-forest)] focus:border-transparent bg-white"
      >
        <option value="">Select…</option>
        {serviceTypes.map((opt) => (
          <option value={opt}>{opt}</option>
        ))}
      </select>

      <label for="contact-message" class="text-[1rem] font-semibold text-[var(--color-text)]">
        Message
      </label>
      <textarea
        id="contact-message"
        name="message"
        rows={4}
        class="w-full px-4 py-3 text-[1rem] border border-[var(--color-slate)]/30 rounded-lg focus:outline-none focus:ring-2 focus:ring-[var(--color-forest)] focus:border-transparent resize-y"
      />

      <button
        type="submit"
        class="w-full sm:w-auto px-8 py-4 bg-[var(--color-forest)] text-[var(--color-white)] font-bold text-[1.1rem] rounded-lg shadow-lg hover:bg-[var(--color-forest-light)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-forest)] transition-colors"
      >
        Send request
      </button>
    </form>
  </div>
</section>
<script>
  if (typeof document !== 'undefined' && document.location.search.includes('form=submitted')) {
    const el = document.getElementById('form-success');
    if (el) el.classList.remove('hidden');
  }
</script>
