---
/** Minimalist SVG logo: stylized 'G' with subtle grass blades. Glens Lawnmowing - North Shore */
const { class: className } = Astro.props;
---
<a href="/" class:list={['inline-flex items-center gap-3 no-underline hover:no-underline', className]} aria-label="Glens Lawnmowing - North Shore home">
  <svg
    width="48"
    height="48"
    viewBox="0 0 48 48"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
    class="shrink-0 text-[#1b4332]"
  >
    <!-- Grass blades (subtle, left) -->
    <path d="M8 40 L10 24 L12 40 Z" fill="currentColor" opacity="0.8" />
    <path d="M12 40 L14 22 L16 40 Z" fill="currentColor" opacity="0.6" />
    <!-- Letter G: C-shape with crossbar and descender -->
    <path
      d="M24 10 A12 12 0 0 1 12 24 A12 12 0 0 1 24 38 L36 38 L36 26 L24 26 L24 10 Z"
      fill="currentColor"
    />
  </svg>
  <span class="font-bold text-[1.1rem] text-[var(--color-text)] leading-tight">
    Glens Lawnmowing<br />
    <span class="font-normal text-[0.85rem] text-[var(--color-text-muted)]">North Shore</span>
  </span>
</a>
