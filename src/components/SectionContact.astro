---
/** Contact section: CTA and anchor for #contact. */
---

<section id="contact" class="py-[var(--section-py)] bg-[var(--color-bg-alt)]" aria-labelledby="contact-heading">
  <div class="container-narrow text-center">
    <h2 id="contact-heading" class="text-[var(--text-4xl)] font-bold text-[var(--color-text)] mb-4">
      Get in touch
    </h2>
    <p class="text-[1.1rem] text-[var(--color-text-muted)] max-w-xl mx-auto mb-8">
      Ready for a lawn you’re proud of? Call or email for a free, no-obligation quote.
    </p>
    <a
      href="tel:0800453676"
      class="inline-block px-8 py-4 bg-[var(--color-forest)] text-[var(--color-white)] font-bold text-[1.1rem] rounded-lg shadow-lg hover:bg-[var(--color-forest-light)] no-underline hover:no-underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-forest)] transition-colors"
    >
      0800 GLENS LAWN
    </a>
  </div>
</section>
