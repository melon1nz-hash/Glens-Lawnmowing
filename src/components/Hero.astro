---
/** Hero: full-width high-res background, North Shore messaging, CTA. */
/** Placeholder image: replace src with your own or a licensed stock photo. */
const ctaHref = Astro.props.ctaHref ?? '#contact';
---

<section class="relative min-h-[85vh] flex flex-col justify-end pb-16 md:pb-24 overflow-hidden" aria-label="Hero">
  <!-- Background: replace with your own high-res photo or licensed stock (e.g. friendly operator + mower on North Shore lawn) -->
  <div class="absolute inset-0 bg-[var(--color-forest-dark)]">
    <img
      src="https://images.unsplash.com/photo-1585320806297-9794b3e4eeae?w=1920&q=80"
      alt="Professional lawn care: well-maintained lawn and garden"
      class="absolute inset-0 w-full h-full object-cover opacity-90"
      width="1920"
      height="1080"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-[var(--color-forest)]/50" aria-hidden="true"></div>
  </div>

  <div class="container-narrow relative z-10 text-[var(--color-white)]">
    <h1 class="text-hero font-bold max-w-3xl mb-4 drop-shadow-md">
      Lush North Shore Lawns.<br />Expertly Maintained.
    </h1>
    <p class="text-xl md:text-2xl font-semibold text-white/95 max-w-2xl mb-8" style="font-size: var(--text-xl);">
      The premium choice for a perfect property.
    </p>
    <a
      href={ctaHref}
      class="inline-block px-8 py-4 bg-[var(--color-forest)] text-[var(--color-white)] font-bold text-[1.1rem] rounded-lg shadow-lg hover:bg-[var(--color-forest-light)] no-underline hover:no-underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white transition-colors"
    >
      Get a free quote
    </a>
  </div>
</section>
