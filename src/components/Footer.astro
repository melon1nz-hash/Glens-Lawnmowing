---
/** Footer: contact details, primary North Shore service areas, professional copyright. */
const areas = ['Takapuna', 'Devonport', 'Milford', 'Browns Bay', 'Albany', 'Northcote', 'Birkenhead', 'Glenfield'];
---

<footer class="bg-[var(--color-forest)] text-[var(--color-white)] py-12 mt-auto">
  <div class="container-narrow grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16">
    <div>
      <h3 class="text-[1.25rem] font-bold mb-4 text-[var(--color-white)]">North Shore</h3>
      <p class="text-[1rem] leading-relaxed opacity-95 mb-3">
        Proudly serving Auckland’s North Shore. Primary service areas:
      </p>
      <ul class="text-[1rem] leading-relaxed opacity-95 list-none flex flex-wrap gap-x-4 gap-y-1" aria-label="Service areas">
        {areas.map((area) => (
          <li key={area}>{area}</li>
        ))}
      </ul>
      <p class="text-[0.95rem] mt-3 opacity-90">…and surrounds.</p>
    </div>
    <div>
      <h3 class="text-[1.25rem] font-bold mb-4 text-[var(--color-white)]">Contact</h3>
      <p class="text-[1rem] leading-relaxed opacity-95">
        <a href="tel:0800453676" class="text-[var(--color-white)] underline hover:no-underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white">0800 GLENS LAWN</a><br />
        <a href="mailto:info@glenslawnmowing.co.nz" class="text-[var(--color-white)] underline hover:no-underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white">info@glenslawnmowing.co.nz</a>
      </p>
    </div>
  </div>
  <div class="container-narrow mt-10 pt-8 border-t border-white/20 text-[0.95rem] opacity-90">
    <p>© {new Date().getFullYear()} Glens Lawnmowing. All rights reserved. North Shore, Auckland, New Zealand.</p>
  </div>
</footer>
